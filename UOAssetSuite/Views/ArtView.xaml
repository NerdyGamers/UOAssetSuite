<UserControl x:Class="UOAssetSuite.Views.ArtView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>
        <ListView x:Name="ArtList" ItemsSource="{Binding}">
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="Index" DisplayMemberBinding="{Binding Index}" Width="80"/>
                    <GridViewColumn Header="Preview" Width="100">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <Image Source="{Binding Image}" Width="64" Height="64"/>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                    <GridViewColumn Header="Width" DisplayMemberBinding="{Binding Width}" Width="80"/>
                    <GridViewColumn Header="Height" DisplayMemberBinding="{Binding Height}" Width="80"/>
                </GridView>
            </ListView.View>
        </ListView>
        <StackPanel Grid.Column="1" Margin="10">
            <Button Content="Extract" Margin="0,0,0,5" Width="100"/>
            <Button Content="Import" Margin="0,0,0,5" Width="100"/>
            <Button Content="Remove" Margin="0,0,0,5" Width="100"/>
            <Button Content="Add New" Margin="0,0,0,5" Width="100"/>
        </StackPanel>
    </Grid>
</UserControl>