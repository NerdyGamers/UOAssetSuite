<Window x:Class="UOAssetSuite.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:UOAssetSuite"
        Title="Ultima Online Asset Suite" Height="700" Width="1000"
        WindowStartupLocation="CenterScreen" Closing="Window_Closing">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Border Grid.Row="0" Background="#2C3E50" Padding="10">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Ultima Online Asset Suite" Foreground="White" FontSize="20" FontWeight="Bold" VerticalAlignment="Center"/>
            </StackPanel>
        </Border>
        <TabControl Grid.Row="1" x:Name="MainTabControl" BorderThickness="0">
            <TabItem Header="Art"><local:ArtView DataContext="{Binding ArtVM}"/></TabItem>
            <TabItem Header="Landtiles"><local:LandtilesView DataContext="{Binding LandtilesVM}"/></TabItem>
            <TabItem Header="Animations"><local:AnimationsView DataContext="{Binding AnimationsVM}"/></TabItem>
            <TabItem Header="Gumps"><local:GumpsView DataContext="{Binding GumpsVM}"/></TabItem>
            <TabItem Header="Maps"><local:MapsView DataContext="{Binding MapsVM}"/></TabItem>
            <TabItem Header="Tiledata"><local:TiledataView DataContext="{Binding TiledataVM}"/></TabItem>
        </TabControl>
        <StatusBar Grid.Row="2" Background="#34495E">
            <StatusBarItem><TextBlock Text="{Binding StatusMessage}" Foreground="White" Margin="10,0,0,0"/></StatusBarItem>
        </StatusBar>
    </Grid>
</Window>